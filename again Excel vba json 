Sub TableToJsonAndOpenJsonWithClause()
    
    Dim ws          As Worksheet
    Dim tbl         As ListObject
    Dim lastCol     As Long
    Dim jsonCol     As Long
    Dim tsqlCol     As Long
    Dim i           As Long
    Dim r           As Long
    Dim header      As Range
    Dim jsonString  As String
    Dim tsqlString  As String
    Dim cellValue   As Variant
    Dim cellType    As VbVarType
    Dim sqlType     As String
    
    ' =============================================================
    '                     SETTINGS
    ' =============================================================
    Const TABLE_NAME As String = "T"           ' ← change if needed
    
    On Error GoTo ErrHandler
    
    Set ws = ActiveSheet
    Set tbl = ws.ListObjects(TABLE_NAME)
    
    If tbl Is Nothing Then
        MsgBox "Table named '" & TABLE_NAME & "' not found on active sheet!", vbExclamation
        Exit Sub
    End If
    
    lastCol = tbl.Range.Columns.Count
    jsonCol = tbl.Range.Column + lastCol           ' JSON column
    tsqlCol = jsonCol + 1                           ' OPENJSON column
    
    ' Headers
    With ws.Cells(tbl.Range.Row - 1, jsonCol)
        .Value = "JSON"
        .Font.Bold = True
        .HorizontalAlignment = xlCenter
    End With
    
    With ws.Cells(tbl.Range.Row - 1, tsqlCol)
        .Value = "OPENJSON WITH"
        .Font.Bold = True
        .HorizontalAlignment = xlCenter
    End With
    
    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    
    ' ────────────────────────────────
    '   Generate OPENJSON WITH clause
    '   (same for all rows)
    ' ────────────────────────────────
    tsqlString = "SELECT *" & vbCrLf & _
                 "FROM OPENJSON(@json)" & vbCrLf & _
                 "WITH (" & vbCrLf
    
    Set header = tbl.HeaderRowRange
    
    For i = 1 To lastCol
        Dim colName As String
        Dim sqlColName As String
        Dim jsonPath As String
        
        colName = header.Cells(1, i).Value
        
        ' Column name in SQL alias - square brackets when needed
        If InStr(colName, " ") > 0 Or InStr(colName, "-") > 0 Or InStr(colName, ".") > 0 Then
            sqlColName = "[" & colName & "]"
        Else
            sqlColName = colName
        End If
        
        ' JSON path - quoted when contains space
        If InStr(colName, " ") > 0 Then
            jsonPath = "'$." & """" & colName & """" & "'"
        Else
            jsonPath = "'$." & colName & "'"
        End If
        
        ' Very basic type detection (based on first data row)
        cellValue = tbl.DataBodyRange.Cells(1, i).Value
        cellType = VarType(cellValue)
        
        Select Case True
            Case IsEmpty(cellValue) Or cellValue = ""
                sqlType = "nvarchar(4000)"
            Case cellType = vbString
                sqlType = "nvarchar(4000)"
            Case cellType >= vbInteger And cellType <= vbDouble
                If InStr(1, CStr(cellValue), ".") > 0 Or cellType = vbDouble Then
                    sqlType = "decimal(18,4)"
                Else
                    sqlType = "bigint"
                End If
            Case cellType = vbDate
                If Int(cellValue) = cellValue Then
                    sqlType = "date"
                Else
                    sqlType = "datetime2(0)"
                End If
            Case Else
                sqlType = "nvarchar(4000)"
        End Select
        
        tsqlString = tsqlString & "    " & _
                     Left(sqlColName & Space(40), 40) & _
                     sqlType & Space(6) & _
                     jsonPath
        
        If i < lastCol Then tsqlString = tsqlString & "," & vbCrLf
    Next i
    
    tsqlString = tsqlString & vbCrLf & ")"
    
    ' ────────────────────────────────
    '        Process each row
    ' ────────────────────────────────
    For r = 1 To tbl.DataBodyRange.Rows.Count
        
        jsonString = "{"
        
        For i = 1 To lastCol
            cellValue = tbl.DataBodyRange.Cells(r, i).Value
            cellType = VarType(cellValue)
            
            jsonString = jsonString & """" & header.Cells(1, i).Value & """:"
            
            If IsEmpty(cellValue) Or cellValue = "" Then
                jsonString = jsonString & "null"
                
            ElseIf cellType = vbString Then
                jsonString = jsonString & """" & _
                             Replace(Replace(Replace(cellValue, "\", "\\"), """", "\"""), vbLf, "\n") & """"
                             
            ElseIf cellType >= vbInteger And cellType <= vbDouble Then
                jsonString = jsonString & """" & CStr(cellValue) & """"
                
            ElseIf cellType = vbDate Then
                If Int(cellValue) = cellValue Then
                    jsonString = jsonString & """" & Format(cellValue, "yyyy-mm-dd") & """"
                Else
                    jsonString = jsonString & """" & Format(cellValue, "yyyy-mm-dd hh:nn:ss") & """"
                End If
                
            Else
                jsonString = jsonString & """" & _
                             Replace(Replace(CStr(cellValue), "\", "\\"), """", "\""") & """"
            End If
            
            If i < lastCol Then jsonString = jsonString & ", "
        Next i
        
        jsonString = jsonString & "}"
        
        ' Write results
        ws.Cells(tbl.DataBodyRange.Row + r - 1, jsonCol).Value = jsonString
        ws.Cells(tbl.DataBodyRange.Row + r - 1, tsqlCol).Value = tsqlString
        
    Next r
    
CleanExit:
    Application.Calculation = xlCalculationAutomatic
    Application.ScreenUpdating = True
    MsgBox "Conversion completed.", vbInformation
    Exit Sub

ErrHandler:
    MsgBox "Error " & Err.Number & vbCrLf & Err.Description, vbCritical
    Resume CleanExit
End Sub