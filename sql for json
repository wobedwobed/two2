DROP TABLE IF EXISTS #tmp
SELECT 
    j.[key] AS json_id
    --,j.[value]
    ,jj.[KEY], jj.[VALUE]
    --,*
INTO #tmp
FROM OPENJSON(@json) j
OUTER APPLY (
    SELECT *
    FROM OPENJSON(j.value)
    ) jj

SELECT *
FROM #tmp
ORDER BY 1, 2

