DECLARE @list NVARCHAR(MAX) = (
SELECT 
    STUFF(
        (SELECT DISTINCT ', [' + [key] + ']'
         FROM #tmp
         FOR XML PATH(''), TYPE
        ).value('.', 'nvarchar(max)'), 
        1, 2, ''
    ) AS wynik
)
SELECT @list

SELECT *
FROM #tmp
PIVOT (MAX([value]) FOR [key] IN ([author], [genre], [literaryPeriod], [mainCharacter], [pricePLN], [publicationDate], [setting], [title])) AS pt
ORDER BY 1, 2

