SELECT 
    execution_id, 
    folder_name, 
    project_name, 
    package_name, 
    status, 
    start_time, 
    end_time,
    parent_execution_id  -- To pole łączy pakiet podrzędny z nadrzędnym
FROM [SSISDB].[catalog].[executions]
WHERE parent_execution_id IS NOT NULL
ORDER BY start_time DESC;
